# ---------------------------------------------------------------------------
# AXIS AI — Contracts (.env)
# ---------------------------------------------------------------------------

# JSON-RPC endpoint for the target network (e.g. http://127.0.0.1:8545 for the
# local Hardhat node, or an Infura/Alchemy URL for a public network).
RPC_URL=http://127.0.0.1:8545

# Chain id of the target network (31337 = Hardhat local).
CHAIN_ID=31337

# Private key of the deploying account (NEVER commit a real key).
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Comma-separated list of initial (genesis) validator addresses. If omitted,
# the deployer becomes the sole bootstrap validator.
INITIAL_VALIDATORS=

# Etherscan-compatible API key for `hardhat verify` (optional on local nets).
ETHERSCAN_API_KEY=
