# ---------------------------------------------------------------------------
# AXIS AI — Marketplace (.env)
# ---------------------------------------------------------------------------
NODE_ENV=development
MARKETPLACE_PORT=5000
MARKETPLACE_HOST=0.0.0.0

# Shared infrastructure
DATABASE_URL=postgres://axis:axis@localhost:5432/axis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# PoAIW engine (used to score compute-job deliveries)
ENGINE_URL=http://localhost:4000
# Must match the engine's ENGINE_INTERNAL_KEY (if the engine guard is enabled).
ENGINE_INTERNAL_KEY=

# Chain / escrow
RPC_URL=http://localhost:8545
AXIS_TOKEN_ADDRESS=
VALIDATOR_REGISTRY_ADDRESS=
MARKETPLACE_ESCROW_ADDRESS=
# Validator-authorised operator key for on-chain escrow settlement. It can mint
# AXIS — keep it private and funded. In production with ESCROW_ONCHAIN=true the
# service REFUSES to boot if this is unset or a public Hardhat/test key.
MARKETPLACE_PRIVATE_KEY=
# Mirror settlement on-chain (requires requesters to lock funds in escrow)
ESCROW_ONCHAIN=false

# --- Market safety caps (on-chain settlement is bounded by these) ---
# The ONLY address the on-chain miner-fee share is released to — a server-owned
# operator EOA, never a client-supplied address. Required (valid address) when
# ESCROW_ONCHAIN=true in production; must NOT be the registry contract address.
MARKET_MINER_WALLET=
# Max trade size accepted per quote (bounds notional + any on-chain mint).
MARKET_MAX_AMOUNT=100000
# Hard ceiling (AXIS) on the miner-fee share settled on-chain per fill. Larger
# fills are still recorded off-chain but skip on-chain settlement.
MARKET_MAX_FILL_AXIS=50

# Pricing engine
PRICING_BASE_PRICE=1.0
PRICING_INTERVAL_MS=60000

# Jobs
JOB_TIMEOUT_SECONDS=1800
JOB_MIN_QUALITY=0.5

LOG_LEVEL=info
