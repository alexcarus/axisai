# ===========================================================================
# AXIS AI — Combined environment for all services.
# Copy to .env and fill in. start.sh appends the deployed contract addresses.
# ===========================================================================

# ------------------------------ SHARED ------------------------------------ #
NODE_ENV=development
LOG_LEVEL=info

# Shared PostgreSQL
POSTGRES_USER=axis
POSTGRES_PASSWORD=axis
POSTGRES_DB=axis
DATABASE_URL=postgres://axis:axis@localhost:5432/axis

# Shared Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ------------------------------ CHAIN ------------------------------------- #
RPC_URL=http://localhost:8545
CHAIN_ID=31337
DEPLOY_CHAIN_ID=31337
# Deployer (Hardhat account #0 by default — DO NOT use on public networks)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Comma-separated genesis validators (defaults to the deployer if empty)
INITIAL_VALIDATORS=
ETHERSCAN_API_KEY=

# ---- Base deployment (public network) ----
# To deploy to Base, set DEPLOYER_PRIVATE_KEY to a FUNDED, SECRET key (never the
# hardhat test key above) and run from packages/contracts:
#   Base Sepolia (testnet): npm run deploy:base-sepolia
#   Base mainnet:           npm run deploy:base
# Optionally point at a private RPC for reliability; defaults to the public ones.
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Basescan API key for contract verification (https://basescan.org/myapikey).
BASESCAN_API_KEY=

# Contract addresses — populated automatically by start.sh after deployment
AXIS_TOKEN_ADDRESS=
VALIDATOR_REGISTRY_ADDRESS=
MARKETPLACE_ESCROW_ADDRESS=

# Validator key used by the engine to submit on-chain PoAIW proofs (mint).
# MUST be a member of the ValidatorRegistry (Hardhat account #0 by default).
VALIDATOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ------------------------- VERIFICATION ENGINE ---------------------------- #
ENGINE_PORT=4000
ENGINE_HOST=0.0.0.0
ENGINE_URL=http://localhost:4000
# Optional: when set, the engine rejects any request without this header,
# so only the gateway/marketplace (which forward it) can reach it. Strongly
# recommended in production — the engine should never be publicly exposed.
ENGINE_INTERNAL_KEY=
MIN_QUALITY=0.5
COOLDOWN_SECONDS=60
PEER_SAMPLE_SIZE=3
PEER_CACHE_LIMIT=500
QUEUE_NAME=axis-verification
QUEUE_CONCURRENCY=4

# ------------------------------ GATEWAY ----------------------------------- #
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
GATEWAY_URL=http://localhost:3000
# Origins allowed to call the gateway from a browser (the web miner).
# Comma-separated, or "*" for any. Set to your site origin in production,
# e.g. https://axis.ai,https://www.axis.ai
CORS_ORIGIN=*
IP_RATE_PER_MINUTE=100
# Per-wallet submit cooldown (seconds). The in-browser miner derives one wallet,
# so for an aggressive public mining launch lower this (e.g. 2–5). Keep it
# higher (60) if you want to throttle each wallet hard.
WALLET_SUBMIT_COOLDOWN=60
BAN_VIOLATION_THRESHOLD=5
BAN_SECONDS=900
NONCE_TTL_SECONDS=3600
AUTH_MAX_AGE_SECONDS=300
ANOMALY_IP_THRESHOLD=3
ANOMALY_WINDOW_SECONDS=3600

# ----------------------------- TELEGRAM BOT ------------------------------- #
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_DOMAIN=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_PORT=8080
# Deterministic mining-wallet derivation secret (SHARED by both bots)
BOT_SIGNER_SECRET=axis-dev-signer-secret-change-me
SUBMIT_COOLDOWN_SECONDS=60
# Web miner the bot's /export command links to (opens the import panel ready
# for the user to paste their exported key). Point at your deployed site.
WEB_MINER_URL=https://axis.ai/?import=1

# ---------------------------- WHATSAPP AGENT ------------------------------ #
WHATSAPP_PORT=8090
WHATSAPP_HOST=0.0.0.0
GRAPH_API_VERSION=v19.0
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=axis-verify-token

# ----------------------------- MARKETPLACE -------------------------------- #
MARKETPLACE_PORT=5000
MARKETPLACE_HOST=0.0.0.0
# Origins allowed to call the market endpoints from a browser (the AXIS Market).
# Comma-separated, or "*" for any. (CORS_ORIGIN is shared with the gateway.)
# AXIS Market (AI trading) — quote pricing and liquidity↔miner fee split.
MARKET_BASE_PRICE=2.41
MARKET_FEE_RATE=0.005
MARKET_LP_SHARE=0.6
MARKET_MINER_SHARE=0.4
MARKET_BASE_SPREAD=0.008
MARKET_AI_SPREAD=0.002
MARKET_QUOTE_TTL=30
# Miner account credited the AI fee when an order doesn't name one
# (defaults to VALIDATOR_REGISTRY_ADDRESS).
MARKET_MINER_WALLET=
MARKETPLACE_ESCROW_ADDRESS=
MARKETPLACE_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
ESCROW_ONCHAIN=false
PRICING_BASE_PRICE=1.0
PRICING_INTERVAL_MS=60000
JOB_TIMEOUT_SECONDS=1800
JOB_MIN_QUALITY=0.5
