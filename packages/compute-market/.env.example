# ---------------------------------------------------------------------------
# AXIS AI Compute Market (.env)  — activates after Genesis (25% of supply)
# ---------------------------------------------------------------------------
PORT=4100
RPC_URL=https://base-rpc.publicnode.com
AXIS_TOKEN_ADDRESS=0x6DBBd1910BeFC6736b818d4DcaD3ff833b9e06D7

# --- Distributed market (miners serve requests) ---
# Treasury wallet: receives buyers' AXIS and pays out the serving miner.
# When set, payTo is derived from it automatically. KEEP SECRET.
TREASURY_PRIVATE_KEY=
# Share of each buyer payment paid to the miner (rest is protocol fee).
MINER_SHARE=0.9

# Only needed for the optional operator-direct /infer path (no miners):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Fallback collect-only address if no treasury key is set:
COMPUTE_MARKET_PAYTO=

# Optional per-tier model overrides
MODEL_FAST=
MODEL_BALANCED=
MODEL_PRO=

# Tiered AXIS pricing — better model = more AXIS, lighter model = cheap access
PRICE_FAST_AXIS=10
PRICE_BALANCED_AXIS=50
PRICE_PRO_AXIS=250

# Confirmations a payment must have before it's accepted. 1 = mined (default, no
# added wait). Raise to 2-3 for reorg protection on higher-value deployments —
# the verifier waits briefly for the extra blocks so the client flow still works.
PAYMENT_MIN_CONFIRMATIONS=1

# Redis (job queue + anti-replay)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
