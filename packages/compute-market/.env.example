# ---------------------------------------------------------------------------
# AXIS AI Compute Market (.env)  — activates after Genesis (25% of supply)
# ---------------------------------------------------------------------------
PORT=4100
RPC_URL=https://base-rpc.publicnode.com
AXIS_TOKEN_ADDRESS=0x6DBBd1910BeFC6736b818d4DcaD3ff833b9e06D7

# --- Distributed market (miners serve requests) ---
# Treasury wallet: receives buyers' AXIS and pays out the serving miner.
# When set, payTo is derived from it automatically. KEEP SECRET.
TREASURY_PRIVATE_KEY=
# Share of each buyer payment paid to the miner (rest is protocol fee).
MINER_SHARE=0.9

# Only needed for the optional operator-direct /infer path (no miners):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Fallback collect-only address if no treasury key is set:
COMPUTE_MARKET_PAYTO=

# Optional per-tier model overrides
MODEL_FAST=
MODEL_BALANCED=
MODEL_PRO=

# Tiered AXIS pricing — better model = more AXIS, lighter model = cheap access
PRICE_FAST_AXIS=10
PRICE_BALANCED_AXIS=50
PRICE_PRO_AXIS=250

# Confirmations a payment must have before it's accepted. 1 = mined (default, no
# added wait). Raise to 2-3 for reorg protection on higher-value deployments —
# the verifier waits briefly for the extra blocks so the client flow still works.
PAYMENT_MIN_CONFIRMATIONS=1

# --- Operator-direct fallback ---
# If a paid job sits queued this long with no distributed miner claiming it, the
# market serves it itself using the AI key above. 0 disables. Needs an AI key.
OPERATOR_FALLBACK_SECONDS=25

# --- Cost-coverage auto-sell (OFF by default) ---
# When on, every fulfilled job's AXIS protocol fee is partly sold for ETH on the
# live Uniswap v4 ETH/AXIS pool (Base) so the treasury refills the gas it spends
# — self-funding, no contract change. It REFUSES to sell if the price impact
# exceeds AUTO_SELL_MAX_IMPACT_BPS, so it won't dump into a thin pool: it only
# starts working once the pool has real liquidity (see LIQUIDITY_RUNBOOK).
# Requires TREASURY_PRIVATE_KEY. Bootstrap the treasury with a little Base ETH
# for the first swaps' gas; after that the sales keep it topped up.
AUTO_SELL_ENABLED=false
AUTO_SELL_MAX_AXIS=50
AUTO_SELL_SLIPPAGE_BPS=100
AUTO_SELL_MAX_IMPACT_BPS=300

# Validator gas top-up (uses the ETH the auto-sell brings in). Set this to the
# validator's public address — the key that signs on-chain mining mints — and
# when its Base ETH drops below VALIDATOR_MIN_ETH the treasury forwards it
# VALIDATOR_TOPUP_ETH, but never below TREASURY_RESERVE_ETH of its own ETH.
# Leave VALIDATOR_WALLET empty to disable the top-up.
VALIDATOR_WALLET=
VALIDATOR_MIN_ETH=0.003
VALIDATOR_TOPUP_ETH=0.01
TREASURY_RESERVE_ETH=0.005

# Redis (job queue + anti-replay)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
