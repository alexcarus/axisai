# ---------------------------------------------------------------------------
# AXIS AI — Telegram Bot (.env)
# ---------------------------------------------------------------------------
# Get a token from @BotFather
TELEGRAM_BOT_TOKEN=

# Webhook mode (production). Leave TELEGRAM_WEBHOOK_DOMAIN empty for local
# long-polling development.
TELEGRAM_WEBHOOK_DOMAIN=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_PORT=8080

# Services
GATEWAY_URL=http://localhost:3000
RPC_URL=http://localhost:8545
DATABASE_URL=postgres://axis:axis@localhost:5432/axis

# Deterministic mining-wallet derivation secret (KEEP SECRET, set per deployment)
BOT_SIGNER_SECRET=axis-dev-signer-secret-change-me

SUBMIT_COOLDOWN_SECONDS=60
LOG_LEVEL=info
