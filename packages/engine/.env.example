# ---------------------------------------------------------------------------
# AXIS AI — Verification Engine (.env)
# ---------------------------------------------------------------------------
NODE_ENV=development

# API
ENGINE_PORT=4000
ENGINE_HOST=0.0.0.0
# Optional internal-key guard (set the same value on gateway + marketplace).
# When set, only callers presenting `x-internal-key` may reach the engine.
ENGINE_INTERNAL_KEY=

# PostgreSQL (shared with bots/gateway/marketplace)
DATABASE_URL=postgres://axis:axis@localhost:5432/axis

# Redis (shared)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Chain / contracts (populated by the contract deploy step)
RPC_URL=http://localhost:8545
DEPLOY_CHAIN_ID=31337
AXIS_TOKEN_ADDRESS=
VALIDATOR_REGISTRY_ADDRESS=
# Private key of a REGISTERED validator — used to submit on-chain proofs/mint.
VALIDATOR_PRIVATE_KEY=

# Verification tuning
MIN_QUALITY=0.5
COOLDOWN_SECONDS=60
PEER_SAMPLE_SIZE=3
PEER_CACHE_LIMIT=500

# Queue
QUEUE_NAME=axis-verification
QUEUE_CONCURRENCY=4

# Logging
LOG_LEVEL=info
