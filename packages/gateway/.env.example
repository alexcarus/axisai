# ---------------------------------------------------------------------------
# AXIS AI — API Gateway (.env)
# ---------------------------------------------------------------------------
NODE_ENV=development
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0

# Upstream verification engine
ENGINE_URL=http://localhost:4000
# Must match the engine's ENGINE_INTERNAL_KEY (if the engine guard is enabled).
ENGINE_INTERNAL_KEY=

# Shared infrastructure
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
DATABASE_URL=postgres://axis:axis@localhost:5432/axis

# DDoS / rate limiting
IP_RATE_PER_MINUTE=100
WALLET_SUBMIT_COOLDOWN=60
BAN_VIOLATION_THRESHOLD=5
BAN_SECONDS=900

# Nonce + auth
NONCE_TTL_SECONDS=3600
AUTH_MAX_AGE_SECONDS=300

# Anomaly detection
ANOMALY_IP_THRESHOLD=3
ANOMALY_WINDOW_SECONDS=3600

LOG_LEVEL=info
