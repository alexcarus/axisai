FEE_PAYER_PRIVATE_KEY=0x...
REALM=mpp.dev
RPC_URL=https://user:pass@rpc.moderato.tempo.xyz
STRIPE_NETWORK_ID=internal
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_DEFAULT_CURRENCY=0x20c0000000000000000000000000000000000000
VITE_DEFAULT_RECIPIENT=0xa726a1CD723409074DF9108A2187cfA19899aCF8
VITE_DEMO_LIVE=true
# AXIS AI — point the in-browser miner at a live gateway (packages/gateway).
# Leave blank to run the miner in local simulation mode.
VITE_AXIS_GATEWAY_URL=http://localhost:3000
# AXIS Market (AI trading) — live market gateway (packages/marketplace).
# Leave blank to run the market locally.
VITE_AXIS_MARKET_URL=http://localhost:5000
# AXIS Telegram bot — @username, bare username, or full t.me URL. When set, the
# web miner shows a "mining on Telegram? /export and paste your key" hint so a
# Telegram user can mine to the same wallet on the web. Leave blank to hide it.
VITE_TELEGRAM_BOT=
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_POSTHOG_KEY=phc_...
VITE_AHREFS_VERIFICATION=ahrefs-site-verification_...
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
BRANDDEV_LOGOLINK_KEY=brandLL_...
